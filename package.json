{
  "name": "glubox",
  "version": "0.1.12",
  "description": "Librería de componentes React para aplicaciones empresariales — Sidebar RBAC, PageActionsMenu, DataGrid, formularios, Popup, Toast, botones y temas pastel",
  "type": "module",
  "license": "MIT",
  "author": "solivoo",
  "keywords": [
    "react",
    "components",
    "sidebar",
    "rbac",
    "design-system",
    "typescript",
    "textbox",
    "select",
    "datepicker",
    "popup",
    "modal",
    "toast",
    "notification",
    "datagrid",
    "table",
    "textarea"
  ],
  "homepage": "https://solivoo.github.io/gluebox/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solivoo/gluebox.git"
  },
  "bugs": {
    "url": "https://github.com/solivoo/gluebox/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/glubox.js",
    "dist/glubox.css",
    "dist/themes",
    "dist/src"
  ],
  "main": "./dist/glubox.js",
  "module": "./dist/glubox.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/glubox.js"
    },
    "./style.css": "./dist/glubox.css",
    "./themes/default.css": "./dist/themes/default.css",
    "./themes/modern.css": "./dist/themes/modern.css",
    "./themes/enterprise.css": "./dist/themes/enterprise.css",
    "./themes/index.css": "./dist/themes/index.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts && node scripts/copy-themes.mjs",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublish:lib": "pnpm clean:dist && pnpm build:lib",
    "prepublishOnly": "pnpm clean:dist && pnpm build:lib",
    "publish:lib": "npm publish --access public",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "themes:generate": "vitest run --config vitest.generate-themes.config.ts",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.5.1"
}
